# LLM — choose one provider
LLM_PROVIDER=openai           # openai | groq | ollama
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# Provider keys (only the one you use is required)
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
OLLAMA_BASE_URL=http://localhost:11434

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=qa_docs

# Retrieval
TOP_K=4
CONTEXT_SCORE_THRESHOLD=0.3

# === V2 ADDITIONS ===

# Persistent Conversation Memory
DATABASE_MEMORY_URL=sqlite:///./data/memory.db

# Langfuse (optional — set LANGFUSE_ENABLED=true to activate)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# LangSmith (optional — set LANGSMITH_ENABLED=true to activate)
LANGSMITH_ENABLED=false
LANGCHAIN_API_KEY=ls__...
LANGSMITH_PROJECT=qa-rag-agent

# LangGraph Debug
LANGGRAPH_DEBUG=false   # true → verbose node logs

# Tavily Web Search (optional — used when web search is enabled in sidebar)
TAVILY_API_KEY=tvly-...

# === V7 ADDITIONS ===

# Checkpointing (optional — graph state persistence for time-travel debugging)
CHECKPOINT_DB_PATH=./data/checkpoints.db
CHECKPOINT_ENABLED=true
